@{
    ViewData["Title"] = "Page Administrateur";
}

<div class="page-heading">
    <span class="eyebrow">Admin</span>
    <h1>Espace administrateur</h1>
    <p>Gère les catégories et les exercices disponibles dans le catalogue.</p>
</div>

<div class="action-grid">
    <a class="action-tile" asp-controller="Admin" asp-action="ListExoCat">
        <strong>Catalogue</strong>
        <span>Lister les catégories et exercices.</span>
    </a>
    <a class="action-tile" asp-controller="Admin" asp-action="CreateExoCat">
        <strong>Nouvelle catégorie</strong>
        <span>Créer un groupe musculaire.</span>
    </a>
    <a class="action-tile" asp-controller="Admin" asp-action="CreateExercice">
        <strong>Nouvel exercice</strong>
        <span>Ajouter un exercice au catalogue.</span>
    </a>
</div>
